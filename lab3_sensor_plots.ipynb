  {
   "cell_type": "code",
   "execution_count": null,
   "id": "boxplot-sensor-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Boxplot comparing the two sensors\n",
    "plt.figure(figsize=(6,4))\n",
    "bp = plt.boxplot([sensor_a, sensor_b], labels=['Sensor A', 'Sensor B'], showmeans=True, patch_artist=True)\n",
    "\n",
    "# Color the boxes\n",
    "colors = ['C0', 'C1']\n",
    "for patch, color in zip(bp['boxes'], colors):\n",
    "    patch.set_facecolor(color)\n",
    "\n",
    "plt.ylabel('Temperature (°C)')\n",
    "plt.title('Boxplot of Sensor Temperatures')\n",
    "plt.grid(True, axis='y')\n",
    "plt.show()\n"
   ]
  }
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "generate-sensor-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "# Replace 1234 with the last 4 digits of your Drexel ID\n",
    "seed = 1234\n",
    "rng = np.random.default_rng(seed)\n",
    "n = 200\n",
    "\n",
    "# timestamps from 0 to 10 seconds\n",
    "timestamps = rng.uniform(0.0, 10.0, n)\n",
    "\n",
    "# Sensor readings (Celsius)\n",
    "sensor_a = rng.normal(loc=25.0, scale=3.0, size=n)\n",
    "sensor_b = rng.normal(loc=27.0, scale=4.5, size=n)\n",
    "\n",
    "# Sort by time for plotting convenience\n",
    "idx = np.argsort(timestamps)\n",
    "timestamps, sensor_a, sensor_b = timestamps[idx], sensor_a[idx], sensor_b[idx]\n",
    "\n",
    "# Verify shapes (optional)\n",
    "assert timestamps.shape == (200,)\n",
    "assert sensor_a.shape == (200,)\n",
    "assert sensor_b.shape == (200,)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "histogram-sensor-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Histogram of sensor readings\n",
    "plt.figure(figsize=(8,4))\n",
    "bins = 20\n",
    "plt.hist(sensor_a, bins=bins, alpha=0.6, label='Sensor A', color='C0')\n",
    "plt.hist(sensor_b, bins=bins, alpha=0.6, label='Sensor B', color='C1')\n",
    "\n",
    "# Draw vertical lines at the means\n",
    "plt.axvline(sensor_a.mean(), color='C0', linestyle='--', linewidth=1, label=f"A mean {sensor_a.mean():.2f}°C")\n",
    "plt.axvline(sensor_b.mean(), color='C1', linestyle='--', linewidth=1, label=f"B mean {sensor_b.mean():.2f}°C")\n",
    "\n",
    "plt.xlabel('Temperature (°C)')\n",
    "plt.ylabel('Count')\n",
    "plt.title('Histogram of Sensor Temperatures')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ]
  }
